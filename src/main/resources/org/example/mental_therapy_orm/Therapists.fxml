<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="680.0" prefWidth="1160.0" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.mental_therapy_orm.controller.TherapistsController">
    <children>

        <VBox layoutX="40.0" layoutY="30.0" spacing="4.0">
            <children>
                <Label style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #114bdf; -fx-letter-spacing: -0.5px;" text="Therapist Management" />
                <Label style="-fx-font-size: 14px; -fx-text-fill: #64748B;" text="Manage professional staff records, specialties, and contact profiles efficiently." />
            </children>
        </VBox>


        <AnchorPane layoutX="40.0" layoutY="110.0" prefHeight="530.0" prefWidth="490.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(15, 23, 42, 0.03), 12, 0, 0, 4);">
            <children>
                <GridPane hgap="15" layoutX="24.0" layoutY="24.0" vgap="16.0">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="110.0" />
                        <ColumnConstraints prefWidth="315.0" />
                    </columnConstraints>
                    <children>

                        <Label style="-fx-font-weight: 700; -fx-text-fill: #475569; -fx-font-size: 13px;" text="Therapist ID" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="txtTherapistId" promptText="e.g. TH-001" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-padding: 10; -fx-text-fill: #0F172A; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0" />


                        <Label style="-fx-font-weight: 700; -fx-text-fill: #475569; -fx-font-size: 13px;" text="Full Name" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="txtName" promptText="Enter therapist's name" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #CBD5E1; -fx-border-width: 1; -fx-padding: 10; -fx-text-fill: #0F172A;" GridPane.columnIndex="1" GridPane.rowIndex="1" />


                        <Label style="-fx-font-weight: 700; -fx-text-fill: #475569; -fx-font-size: 13px;" text="Specialization" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="txtSpecialization" promptText="e.g. Clinical Psychologist, Counselor" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #CBD5E1; -fx-border-width: 1; -fx-padding: 10; -fx-text-fill: #0F172A;" GridPane.columnIndex="1" GridPane.rowIndex="2" />


                        <Label style="-fx-font-weight: 700; -fx-text-fill: #475569; -fx-font-size: 13px;" text="Phone" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <TextField fx:id="txtPhone" promptText="e.g. +94 7X XXX XXXX" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #CBD5E1; -fx-border-width: 1; -fx-padding: 10; -fx-text-fill: #0F172A;" GridPane.columnIndex="1" GridPane.rowIndex="3" />


                        <Label style="-fx-font-weight: 700; -fx-text-fill: #475569; -fx-font-size: 13px;" text="Email" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <TextField fx:id="txtEmail" promptText="name@therapy.com" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #CBD5E1; -fx-border-width: 1; -fx-padding: 10; -fx-text-fill: #0F172A;" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    </children>
                    <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                    </rowConstraints>
                </GridPane>


                <HBox layoutX="24.0" layoutY="465.0" spacing="12.0">
                    <children>
                        <Button fx:id="btnSave" onAction="#btnSaveOnAction" prefHeight="40.0" prefWidth="105.0" style="-fx-background-color: #6366F1; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(99, 102, 241, 0.2), 6, 0, 0, 2);" text="Save" />
                        <Button fx:id="btnUpdate" onAction="#btnUpdateOnAction" prefHeight="40.0" prefWidth="105.0" style="-fx-background-color: #0EA5E9; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(14, 165, 233, 0.2), 6, 0, 0, 2);" text="Update" />
                        <Button fx:id="btnDelete" onAction="#btnDeleteOnAction" prefHeight="40.0" prefWidth="105.0" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(239, 68, 68, 0.15), 6, 0, 0, 2);" text="Delete" />
                        <Button fx:id="btnClear" onAction="#btnClearOnAction" prefHeight="40.0" prefWidth="105.0" style="-fx-background-color: #F1F5F9; -fx-text-fill: #64748B; -fx-background-radius: 8; -fx-font-weight: bold; -fx-font-size: 13px; -fx-border-radius: 8; -fx-border-color: #E2E8F0; -fx-cursor: hand;" text="Clear" />
                    </children>
                </HBox>
            </children>
        </AnchorPane>


        <TableView fx:id="tblTherapists" layoutX="555.0" layoutY="110.0" prefHeight="530.0" prefWidth="565.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #E2E8F0; -fx-effect: dropshadow(three-pass-box, rgba(15, 23, 42, 0.03), 12, 0, 0, 4); -fx-padding: 6;">
            <columns>
                <TableColumn fx:id="colId" prefWidth="80.0" style="-fx-alignment: CENTER;" text="ID" />
                <TableColumn fx:id="colName" prefWidth="160.0" text="Therapist Name" />
                <TableColumn fx:id="colSpecialization" prefWidth="145.0" text="Specialty" />
                <TableColumn fx:id="colPhone" prefWidth="150.0" text="Phone Number" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
</AnchorPane>