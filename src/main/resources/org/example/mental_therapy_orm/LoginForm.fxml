<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: linear-gradient(to bottom right, #050133, #7972ea);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.mental_therapy_orm.controller.LoginFormController">
    <children>
        <!-- Main Container to hold everything Centered -->
        <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="550.0" prefWidth="900.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 20, 0, 0, 10);">
                    <children>

                        <!-- Left Side: Branding Panel -->
                        <VBox alignment="CENTER" prefHeight="550.0" prefWidth="380.0" spacing="25.0" style="-fx-background-color: linear-gradient(to bottom right, #3F3D56, #6C63FF); -fx-background-radius: 20 0 0 20;">
                            <children>
                                <ImageView fitHeight="150.0" fitWidth="150.0" preserveRatio="true">
                                    <image>
                                        <Image url="@assets/mental100-removebg-preview.png" />
                                    </image>
                                </ImageView>
                                <VBox alignment="CENTER" spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-weight: 800; -fx-letter-spacing: 1px;" text="Serenity" textFill="WHITE">
                                            <font>
                                                <Font name="System Bold" size="32.0" />
                                            </font>
                                        </Label>
                                        <Label style="-fx-font-weight: 300;" text="Therapy Center" textFill="#e0e0e0">
                                            <font>
                                                <Font size="18.0" />
                                            </font>
                                        </Label>
                                        <Separator maxWidth="100.0" opacity="0.3" style="-fx-background-color: white;" />
                                        <Label style="-fx-font-opacity: 0.8;" text="Mental Health System" textFill="#d1ccff">
                                            <font>
                                                <Font size="13.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Right Side: Login Form -->
                        <VBox alignment="CENTER_LEFT" prefHeight="550.0" prefWidth="520.0" spacing="22.0" style="-fx-padding: 0 60 0 60; -fx-background-radius: 0 20 20 0; -fx-background-color: white;">
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-weight: 800; -fx-text-fill: #2D3436;" text="Welcome Back">
                                            <font>
                                                <Font name="System Bold" size="28.0" />
                                            </font>
                                        </Label>
                                        <Label text="Login to manage your account" textFill="#b2bec3">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>

                                <VBox spacing="15.0">
                                    <children>
                                        <!-- Username Field -->
                                        <TextField fx:id="txtUsername" prefHeight="45.0" promptText="Username" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #E2E8F0; -fx-border-width: 1.5; -fx-background-color: #F8FAFC; -fx-padding: 10 15 10 15; -fx-font-size: 14px;" />

                                        <!-- Password Field -->
                                        <PasswordField fx:id="txtPassword" prefHeight="45.0" promptText="Password" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #E2E8F0; -fx-border-width: 1.5; -fx-background-color: #F8FAFC; -fx-padding: 10 15 10 15; -fx-font-size: 14px;" />
                                    </children>
                                </VBox>

                                <!-- Show Password Checkbox & Role ComboBox Row -->
                                <HBox alignment="CENTER_LEFT" spacing="30.0">
                                    <children>
                                        <CheckBox fx:id="chkShowPassword" style="-fx-text-fill: #636E72; -fx-font-size: 13px; -fx-cursor: hand;" text="Show Password" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <ComboBox fx:id="cmbRole" prefHeight="35.0" prefWidth="180.0" promptText="Select Role" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-cursor: hand;" />
                                    </children>
                                </HBox>

                                <!-- Login Button -->
                                <Button fx:id="btnLogin" maxWidth="1.7976931348623157E308" onAction="#btnLoginOnAction" prefHeight="45.0" style="-fx-background-color: #6C63FF; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 15px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(108,99,255,0.3), 10, 0, 0, 5);" text="LOGIN" />

                                <!-- Forgot Password Link -->
                                <HBox alignment="CENTER">
                                    <children>
                                        <Hyperlink style="-fx-text-fill: #6C63FF; -fx-font-size: 13px; -fx-underline: false;" text="Change Username / Password" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                    </children>
                </HBox>
            </children>
        </StackPane>
    </children>
</AnchorPane>