<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="631.0" prefWidth="1100.0" style="-fx-background-color: #F4F7FA;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.mental_therapy_orm.controller.SessionScheduleController">
    <children>
        <Label layoutX="40.0" layoutY="15.0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2D3436;" text="Session Schedules" />
        <AnchorPane layoutX="40.0" layoutY="65.0" prefWidth="480.0" prefHeight="470.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
            <children>
                <GridPane hgap="15" vgap="12" layoutX="20" layoutY="20">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="120.0" />
                        <ColumnConstraints prefWidth="300.0" />
                    </columnConstraints>
                    <children>
                        <Label text="Schedule ID" style="-fx-font-weight: bold; -fx-text-fill: #636E72;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtScheduleId" promptText="Enter Schedule ID" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #DFE6E9; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label text="Patient ID" style="-fx-font-weight: bold; -fx-text-fill: #636E72;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <ComboBox fx:id="cmbPatientId" prefWidth="300.0" promptText="Select Patient" style="-fx-background-color: white; -fx-border-color: #DFE6E9; -fx-border-radius: 8;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <Label fx:id="lblPatientDetails" text="..." style="-fx-text-fill: #6C63FF; -fx-font-size: 13px; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Program ID" style="-fx-font-weight: bold; -fx-text-fill: #636E72;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <ComboBox fx:id="cmbProgramId" prefWidth="300.0" promptText="Select Program" style="-fx-background-color: white; -fx-border-color: #DFE6E9; -fx-border-radius: 8;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        
                        <!-- Details Label for Program -->
                        <Label fx:id="lblProgramDetails" text="..." style="-fx-text-fill: #6C63FF; -fx-font-size: 13px; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                        
                        <Label text="Therapist ID" style="-fx-font-weight: bold; -fx-text-fill: #636E72;" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                        <ComboBox fx:id="cmbTherapistId" prefWidth="300.0" promptText="Select Therapist" style="-fx-background-color: white; -fx-border-color: #DFE6E9; -fx-border-radius: 8;" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                        
                        <!-- Details Label for Therapist -->
                        <Label fx:id="lblTherapistDetails" text="..." style="-fx-text-fill: #6C63FF; -fx-font-size: 13px; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                        
                        <Label text="Date" style="-fx-font-weight: bold; -fx-text-fill: #636E72;" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                        <DatePicker fx:id="datePicker" prefWidth="300.0" promptText="Select Date" style="-fx-background-color: white; -fx-border-color: #DFE6E9; -fx-border-radius: 8;" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                        
                        <Label text="Time" style="-fx-font-weight: bold; -fx-text-fill: #636E72;" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
                        <TextField fx:id="txtTime" promptText="HH:MM AM/PM" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #DFE6E9; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="8" />
                    </children>
                </GridPane>
            </children>
        </AnchorPane>
        
        <HBox layoutX="40.0" layoutY="555.0" spacing="15.0">
            <children>
                <Button fx:id="btnSave" onAction="#btnSaveOnAction" prefWidth="110.0" prefHeight="40.0" style="-fx-background-color: #6C63FF; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold;" text="Save" />
                <Button fx:id="btnUpdate" onAction="#btnUpdateOnAction" prefWidth="110.0" prefHeight="40.0" style="-fx-background-color: #00CEC9; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold;" text="Update" />
                <Button fx:id="btnDelete" onAction="#btnDeleteOnAction" prefWidth="110.0" prefHeight="40.0" style="-fx-background-color: #FF7675; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold;" text="Delete" />
                <Button fx:id="btnClear" onAction="#btnClearOnAction" prefWidth="110.0" prefHeight="40.0" style="-fx-background-color: #B2BEC3; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold;" text="Clear" />
            </children>
        </HBox>
        
        <TableView fx:id="tblSchedules" layoutX="540.0" layoutY="65.0" prefHeight="520.0" prefWidth="520.0" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
            <columns>
                <TableColumn fx:id="colId" prefWidth="80.0" text="Schedule" />
                <TableColumn fx:id="colPatientId" prefWidth="90.0" text="Patient" />
                <TableColumn fx:id="colProgramId" prefWidth="90.0" text="Program" />
                <TableColumn fx:id="colTherapistId" prefWidth="90.0" text="Therapist" />
                <TableColumn fx:id="colDate" prefWidth="90.0" text="Date" />
                <TableColumn fx:id="colTime" prefWidth="80.0" text="Time" />
            </columns>
        </TableView>
    </children>
</AnchorPane>
